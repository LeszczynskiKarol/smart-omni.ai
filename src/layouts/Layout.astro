---
interface Props { title?: string }
const { title = "Smart Omni — AI Voice Assistant" } = Astro.props;
---
<!doctype html>
<html lang="pl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content="Głosowy asystent AI — Trello, Gmail, Calendar i więcej" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300..700;1,9..40,300..700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
</head>
<body class="bg-surface-0 text-gray-200 font-sans antialiased min-h-screen">
  <slot />
</body>
</html>

<style is:global>
  * { scrollbar-width: thin; scrollbar-color: #232d3b transparent; }
  ::selection { background: rgba(6,182,212,0.3); }
  body { overflow: hidden; }
  .tok-keyword { color: #c792ea; font-weight: 500; }
  .tok-builtin { color: #82aaff; }
  .tok-string { color: #c3e88d; }
  .tok-number { color: #f78c6c; }
  .tok-comment { color: #546e7a; font-style: italic; }
  .tok-function { color: #ffcb6b; }
  .tok-flag { color: #89ddff; }
  .code-line:hover { background: rgba(255,255,255,0.03); }
  .code-line:hover .code-line-num { color: rgba(255,255,255,0.25); }
  .code-block pre::-webkit-scrollbar { height: 6px; }
  .code-block pre::-webkit-scrollbar-track { background: transparent; }
  .code-block pre::-webkit-scrollbar-thumb { background: #232d3b; border-radius: 3px; }
</style>
